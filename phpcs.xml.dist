<?xml version="1.0"?>
<ruleset name="GitHub Release Posts">
	<description>PHP_CodeSniffer ruleset for the GitHub Release Posts plugin.</description>

	<!-- Files to check -->
	<file>github-release-posts.php</file>
	<file>uninstall.php</file>
	<file>includes/</file>

	<!-- Exclusions -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>

	<!-- WordPress Coding Standards -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

	<!-- Enforce minimum PHP version -->
	<config name="minimum_supported_wp_version" value="6.9"/>
	<config name="testVersion" value="8.0-"/>

	<!-- Set the correct text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="github-release-posts"/>
			</property>
		</properties>
	</rule>

	<!-- Allow short array syntax (PSR-12 / modern PHP convention) -->
	<rule ref="Universal.Arrays.DisallowShortArraySyntax">
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
	</rule>
	<rule ref="Generic.Arrays.DisallowLongArraySyntax"/>

	<!-- PSR-4 autoloading — class file naming follows namespace, not WP convention -->
	<rule ref="WordPress.Files.FileName">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
	</rule>

	<!-- Namespaced code — prefix check not needed -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="Jakemgold\GitHubReleasePosts"/>
				<element value="github_release_posts"/>
				<element value="GITHUB_RELEASE_POSTS"/>
				<element value="ghrp"/>
			</property>
		</properties>
	</rule>
</ruleset>
